{
  "description": "apply_patch with `paths` array iterates entries",
  "tool_name": "apply_patch",
  "tool_input": {
    "paths": [
      "{repo}/a.py",
      "{repo}/b.py"
    ]
  },
  "locks": [
    {
      "path": "{repo}/a.py",
      "agent_id": "agent-me"
    }
  ],
  "expected": {
    "hookSpecificOutput": {
      "hookEventName": "PreToolUse",
      "permissionDecision": "deny",
      "permissionDecisionReason": "path '{repo}/b.py' has no active lock for agent 'agent-me'"
    }
  }
}
