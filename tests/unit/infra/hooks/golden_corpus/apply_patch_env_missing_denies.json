{
  "description": "apply_patch with MALA_* env unset",
  "tool_name": "apply_patch",
  "tool_input": {
    "path": "{repo}/src.py"
  },
  "env_unset": [
    "MALA_AGENT_ID",
    "MALA_REPO_NAMESPACE"
  ],
  "expected": {
